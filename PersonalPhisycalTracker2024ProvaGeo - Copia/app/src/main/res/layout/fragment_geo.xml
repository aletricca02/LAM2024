<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


<fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <Button
        android:id="@+id/add_geofence_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@id/map"
        android:layout_centerInParent="true"
        android:layout_marginBottom="48dp"
        android:text="Add Geofence" />

    <TextView
        android:id="@+id/geofenceStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/add_geofence_button"
        android:layout_centerHorizontal="true"
        android:padding="16dp"
        android:layout_alignBottom="@id/geofenceStatus"
        android:text="Geofence status"
        android:textSize="16sp" />
</RelativeLayout>