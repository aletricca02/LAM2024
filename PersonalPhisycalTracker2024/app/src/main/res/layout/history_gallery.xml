<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    tools:context=".ui.history.HistoryFragment"
    android:background="@color/Navy">

    <CalendarView
        android:id="@+id/calendarView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"/>

    <!-- TextView con la scritta "Scegli un filtro" -->

    <TextView
        android:id="@+id/filter_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Scegli un filtro per la visualizzazione delle attività"
        android:textColor="@color/GhostWhite"
        android:textSize="16sp" />

    <Spinner
        android:id="@+id/filter_Spinner"
        android:layout_width="match_parent"
        android:layout_height="61dp"
        android:layout_below="@id/circleLayout"
        android:layout_marginTop="48dp"
        android:background="@drawable/spinner_background"
        android:padding="10dp"
        android:animateLayoutChanges="true"
        android:textAlignment="center"
        android:popupBackground="@color/SteelBlue"
        android:prompt="@string/choose_activity_prompt" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="344dp"
        android:layout_height="243dp"
        android:layout_below="@id/calendarView"
        android:layout_margin="16dp" />

</LinearLayout>