<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PersonalPhisycalTracker2024" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/DarkCyan</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/AntiqueWhite</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/MediumBlue</item>
        <item name="colorSecondaryVariant">@color/DarkBlue</item>
        <item name="colorOnSecondary">@color/AntiqueWhite</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.PersonalPhisycalTracker2024.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.PersonalPhisycalTracker2024.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.PersonalPhisycalTracker2024.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>